# =========================================
# HireSync AI — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git
# =========================================

# ---- AI (Google Gemini — Free at https://aistudio.google.com) ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- JWT Security ----
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ---- Database ----
POSTGRES_DB=hiresync
POSTGRES_USER=hiresync
POSTGRES_PASSWORD=hiresync_local_password

# ---- Redis ----
REDIS_PASSWORD=

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---- Mail (MailHog local — no real credentials needed) ----
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# ---- Service Ports ----
CORE_SERVICE_PORT=8081
AI_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083

# ---- File Upload ----
UPLOAD_DIR=./uploads

# ---- CORS (Frontend URL) ----
CORS_ALLOWED_ORIGINS=http://localhost:3000
